{
  "id": "j6",
  "name": "Roland J-6",
  "cat": "Chord Synth",
  "color": "#3498db",
  "use": "Chord voicings, arpeggios, melodic phrases, step-sequenced chord progressions",
  "overview": "Chord synthesizer that auto-plays rich voicings and phrases. Turn STYLE + VARIATION knobs to browse 100s of styles. The 16-step sequencer stores chord changes with per-step phrase assignments — each step can have its own style.",
  "workflow": [
    "Press <kbd>STYLE [ON]</kbd> button (lights up) to activate phrase/arp playback",
    "Turn <kbd>[STYLE]</kbd> knob → select a phrase style; turn <kbd>[VARIATION]</kbd> knob → pick variation within that style",
    "Press keyboard buttons to trigger chords — J-6 plays full voicings automatically",
    "Press <kbd>[CHORD]</kbd> button to hear raw chord shapes without the phrase running",
    "<kbd>[SHIFT]</kbd> + <kbd>[C# (OCTAVE-)]</kbd> or <kbd>[SHIFT]</kbd> + <kbd>[D# (OCTAVE+)]</kbd> to shift octave",
    "Record: press <kbd>[REC]</kbd> → press <kbd>[PLAY]</kbd> → play chord changes → press <kbd>[PLAY]</kbd> to stop",
    "Edit a step: select it → hold <kbd>[SHIFT]</kbd> + press <kbd>[B (MENU)]</kbd> → scroll to COPY / PSTE / INSR / DUPL → press <kbd>[D (ENTER)]</kbd>",
    "Hold <kbd>[PATTERN]</kbd> + turn <kbd>[TEMPO/VALUE]</kbd> to change beats per measure (1/4 note / triplet / 1/8 / 1/8 per beat)",
    "<kbd>[SHIFT]</kbd> + <kbd>[A (KEY)]</kbd> → turn <kbd>[TEMPO/VALUE]</kbd> to transpose keyboard → <kbd>[C (EXIT)]</kbd> to exit",
    "<kbd>[SHIFT]</kbd> + <kbd>[C (WRITE)]</kbd> → press <kbd>[D (ENTER)]</kbd> to save pattern"
  ],
  "shortcuts": [
    {
      "cat": "Playback",
      "combo": "STYLE [ON] button",
      "action": "Enable phrase/arp playback ★"
    },
    {
      "cat": "Playback",
      "combo": "[CHORD] button",
      "action": "Play chords without phrase style running"
    },
    {
      "cat": "Playback",
      "combo": "[SHIFT] + [C# (OCTAVE-)]",
      "action": "Octave down"
    },
    {
      "cat": "Playback",
      "combo": "[SHIFT] + [D# (OCTAVE+)]",
      "action": "Octave up"
    },
    {
      "cat": "Sequencer",
      "combo": "[SHIFT] + [E (SHUFFLE)]",
      "action": "Configure shuffle / swing"
    },
    {
      "cat": "Sequencer",
      "combo": "[SHIFT] + [F (LAST)]",
      "action": "Set last step (pattern length)"
    },
    {
      "cat": "Sequencer",
      "combo": "[SHIFT] + [G (CLEAR)]",
      "action": "Initialize pattern (or just the selected step if one is selected)"
    },
    {
      "cat": "Sequencer",
      "combo": "Hold [PATTERN] + turn [TEMPO/VALUE]",
      "action": "Change beats per measure (1-4, 1-3, 1-2, 1–8) ★"
    },
    {
      "cat": "Sequencer",
      "combo": "[SHIFT] + [B (MENU)] → INSR",
      "action": "Insert empty step at selected position"
    },
    {
      "cat": "Sequencer",
      "combo": "[SHIFT] + [B (MENU)] → DUPL",
      "action": "Double pattern (copies all steps, doubles length)"
    },
    {
      "cat": "Sequencer",
      "combo": "[SHIFT] + [B (MENU)] → COPY / PSTE",
      "action": "Copy and paste a step"
    },
    {
      "cat": "Sequencer",
      "combo": "[SHIFT] + [B (MENU)] → A.vLo",
      "action": "Set accent velocity for phrases"
    },
    {
      "cat": "Sequencer",
      "combo": "[SHIFT] + [B (MENU)] → P.chg",
      "action": "Set pattern change timing (at next step, or after N beats)"
    },
    {
      "cat": "Transpose",
      "combo": "[SHIFT] + [A (KEY)]",
      "action": "Transpose keyboard — set value with [TEMPO/VALUE] ★"
    },
    {
      "cat": "Edit / Nav",
      "combo": "[SHIFT] + [D (ENTER)]",
      "action": "Confirm value or selection"
    },
    {
      "cat": "Edit / Nav",
      "combo": "[SHIFT] + [C (EXIT)]",
      "action": "Exit current menu"
    },
    {
      "cat": "Edit / Nav",
      "combo": "[SHIFT] + [B (MENU)]",
      "action": "Open settings menu"
    },
    {
      "cat": "Save",
      "combo": "[SHIFT] + [C (WRITE)] → [D (ENTER)]",
      "action": "Save pattern ★"
    }
  ],
  "tips": [
    "Per-step STYLE: when a step has STYLE:ON it stores its own phrase — style keeps playing even if following steps are STYLE:OFF",
    "When all steps are STYLE:OFF, the pattern-level style applies uniformly to all steps",
    "VARIATION knob: subtle changes within a style — different rhythmic emphasis, not a full new pattern",
    "Use DUPL to double a 4-bar pattern to 8 bars, then edit the second half for a B section"
  ],
